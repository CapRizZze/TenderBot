// Схема данных MVP AI Tender Bot.
// Включает модели NextAuth Prisma Adapter и доменные сущности тендеров.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageRole {
  user
  assistant
  system
}

enum TenderSource {
  government
  commercial
  unknown
}

enum SabyRequestStatus {
  success
  empty
  error
  daily_limit
  blocked
}

enum SearchProfileRuleType {
  positive
  negative
  hard_exclude
  instruction
}

enum TenderScoreVerdict {
  relevant
  maybe
  irrelevant
}

enum SabySourceRefreshPriority {
  high
  medium
  low
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String?        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  conversations Conversation[]
  keywords      UserKeyword[]
  sabyRequests  SabyRequestLog[]
  sabyApiCalls  SabyApiCallLog[]
  searchProfiles SearchProfile[]
  tenderRequestNames TenderRequestName[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

model Tender {
  id            String              @id @default(cuid())
  externalId    String              @unique
  number        String?
  title         String
  description   String
  customer      String
  placedAt      DateTime?
  deadline      DateTime
  budget        Decimal?
  url           String
  sourceUrl     String?
  sabyUrl       String?
  source        TenderSource        @default(unknown)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  conversations Conversation[]
  attachments   TenderAttachment[]
  requestNames  TenderRequestName[]
  profileScores TenderProfileScore[]

  @@index([deadline])
  @@index([placedAt])
  @@index([customer])
  @@index([number])
  @@map("tenders")
}

model SearchProfile {
  id           String                     @id @default(cuid())
  userId       String
  name         String
  description  String
  scoringPrompt String
  isDefault    Boolean                    @default(false)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  user         User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestNames SearchProfileRequestName[]
  sources      SearchProfileSabySource[]
  rules        SearchProfileRule[]
  scores       TenderProfileScore[]

  @@unique([userId, name])
  @@index([userId])
  @@map("search_profiles")
}

model SabySource {
  id                 String                    @id @default(cuid())
  name               String
  requestName        String                    @unique
  description        String                    @default("")
  includeKeywordsText String                   @default("")
  excludeKeywordsText String                   @default("")
  refreshPriority    SabySourceRefreshPriority @default(medium)
  refreshIntervalMin Int                       @default(1440)
  isActive           Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  profiles           SearchProfileSabySource[]

  @@index([isActive, refreshPriority])
  @@map("saby_sources")
}

model SearchProfileSabySource {
  id              String        @id @default(cuid())
  searchProfileId String
  sabySourceId    String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  searchProfile   SearchProfile @relation(fields: [searchProfileId], references: [id], onDelete: Cascade)
  sabySource      SabySource    @relation(fields: [sabySourceId], references: [id], onDelete: Cascade)

  @@unique([searchProfileId, sabySourceId])
  @@index([sabySourceId])
  @@index([searchProfileId])
  @@map("search_profile_saby_sources")
}

model SearchProfileRequestName {
  id              String        @id @default(cuid())
  searchProfileId String
  requestName     String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  searchProfile   SearchProfile @relation(fields: [searchProfileId], references: [id], onDelete: Cascade)

  @@unique([searchProfileId, requestName])
  @@index([requestName])
  @@index([searchProfileId])
  @@map("search_profile_request_names")
}

model SearchProfileRule {
  id              String                @id @default(cuid())
  searchProfileId String
  type            SearchProfileRuleType
  value           String
  weight          Int                   @default(1)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  searchProfile   SearchProfile         @relation(fields: [searchProfileId], references: [id], onDelete: Cascade)

  @@index([searchProfileId, type])
  @@map("search_profile_rules")
}

model TenderProfileScore {
  id              String             @id @default(cuid())
  tenderId        String
  searchProfileId String
  score           Int
  verdict         TenderScoreVerdict
  userVerdict     TenderScoreVerdict?
  userComment     String?
  reasons         Json
  positiveSignals Json?
  negativeSignals Json?
  suggestedRules  Json?
  model           String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tender          Tender             @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  searchProfile   SearchProfile      @relation(fields: [searchProfileId], references: [id], onDelete: Cascade)

  @@unique([tenderId, searchProfileId])
  @@index([searchProfileId, verdict, score])
  @@index([tenderId])
  @@map("tender_profile_scores")
}

model TenderAttachment {
  id                    String    @id @default(cuid())
  tenderId              String
  name                  String
  url                   String
  mimeType              String?
  size                  Int?
  extractedText         String?
  extractedTextAt       DateTime?
  extractedTextError    String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  tender                Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)

  @@unique([tenderId, url])
  @@index([tenderId])
  @@map("tender_attachments")
}

model TenderRequestName {
  id          String   @id @default(cuid())
  tenderId    String
  userId      String?
  requestName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tender      Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenderId, requestName])
  @@index([requestName])
  @@index([tenderId])
  @@index([userId, requestName])
  @@map("tender_request_names")
}

model Conversation {
  id        String    @id @default(cuid())
  userId    String
  tenderId  String
  title     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tender    Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([userId, tenderId])
  @@index([userId])
  @@index([tenderId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  clientMessageId String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@unique([conversationId, clientMessageId])
  @@map("messages")
}

model UserKeyword {
  id        String   @id @default(cuid())
  userId    String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, value])
  @@index([value])
  @@map("user_keywords")
}

model SabyRequestLog {
  id          String            @id @default(cuid())
  userId      String?
  requestName String
  method      String
  status      SabyRequestStatus
  tenderCount Int               @default(0)
  error       String?
  createdAt   DateTime          @default(now())
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([requestName, createdAt])
  @@index([status, createdAt])
  @@map("saby_request_logs")
}

model SabyApiCallLog {
  id                 String    @id @default(cuid())
  userId             String?
  operation          String
  method             String
  endpoint           String
  requestName        String?
  tenderExternalId   String?
  tenderNumber       String?
  status             String
  httpStatus         Int?
  durationMs         Int
  usedRequests       Int?
  dayCounterBefore   Int?
  dayCounterAfter    Int?
  dayRemainingBefore Int?
  dayRemainingAfter  Int?
  payloadSummary     Json?
  responseSummary    Json?
  error              String?
  createdAt          DateTime  @default(now())
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([operation, createdAt])
  @@index([method, createdAt])
  @@index([requestName, createdAt])
  @@map("saby_api_call_logs")
}

   <script type='text/javascript'>
      (function() {
         var InterfaceScript = function () {
            var logoSbis = document.querySelector('.js-logo-sbis');
            var logoSaby = document.querySelector('.js-logo-saby');
            var textAbout = document.querySelector('.js-text-about');

            var _detectSite = function () {
               var hostname = window.location.hostname;
               var site = hostname.replace(/(pre-test|test|fix|rc|dev)\./, '').replace(/\.ru$/, '');

               if (site === 'saby') {
                  logoSbis.parentNode.removeChild(logoSbis);
                  logoSaby.classList.remove('ws-hidden');

                  if (textAbout) {
                     textAbout.innerHTML = 'Saby';
                  }
               } else {
                  logoSaby.parentNode.removeChild(logoSaby);
                  logoSbis.classList.remove('ws-hidden');

                  if (textAbout) {
                     textAbout.innerHTML = 'СБИС';
                  }
               }
            }

            var _prepareLinks = function () {
               var links = document.getElementsByTagName('a');
               var protocol = window.location.protocol;
               var hostname = window.location.hostname.toLowerCase();
               var domain = hostname.split('.').slice(-2).join('.');
               var sitePrefix = hostname.match(/(pre-test|test|fix|rc|dev)(?!:.+)/) && hostname.match(/(pre-test|test|fix|rc|dev)(?!:.+)/)[0];
               if (links && links.length > 0) {
                  for (var i = 0; i < links.length; i++) {
                     var item = links[i];
                     var href = item.getAttribute('href');
                     if (href.startsWith('/')) {
                        item.setAttribute('href', protocol + '//' + (!!sitePrefix ? sitePrefix + '.' : '') + domain + href);
                     }
                  }
               }
            }

            this.init = function () {
               _prepareLinks();
               _detectSite();
            };
         };

         var interfaceInit = new InterfaceScript();

         document.addEventListener("DOMContentLoaded", function () {
            interfaceInit.init();
         });
      }());
   </script>

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_tender_bot?schema=public"

# NextAuth v5
AUTH_SECRET="vasyavasyavasyavasyavasyavasyavasya"
AUTH_URL="http://localhost:3000"

# Email OTP provider
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_SECURE="false"
EMAIL_SERVER_REQUIRE_TLS="true"
EMAIL_SERVER_USER="user@example.com"
EMAIL_SERVER_PASSWORD="replace-with-email-password"
EMAIL_FROM="AI Tender Bot <noreply@example.com>"

# Qwen API через совместимый OpenAI endpoint
QWEN_API_KEY="replace-with-qwen-api-key"
QWEN_BASE_URL="https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
QWEN_MODEL="qwen-plus"

# Внешний REST-парсер тендеров. В MVP используется заглушка сервиса.
TENDER_PARSER_MODE="mock"
TENDER_PARSER_API_URL="https://example.com/api/tenders"

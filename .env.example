# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/ai_tender_bot?schema=public"

# NextAuth v5
AUTH_SECRET="vasyavasyavasyavasyavasyavasyavasya"
AUTH_URL="http://localhost:3000"

# Email OTP provider
EMAIL_SERVER_HOST="smtp.example.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_SECURE="false"
EMAIL_SERVER_REQUIRE_TLS="true"
EMAIL_SERVER_USER="user@example.com"
EMAIL_SERVER_PASSWORD="replace-with-email-password"
EMAIL_FROM="AI Tender Bot <noreply@example.com>"

# DeepSeek API (OpenAI-compatible)
DEEPSEEK_API_KEY="replace-with-deepseek-api-key"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# Parser mode: mock | rest | saby
TENDER_PARSER_MODE="saby"
TENDER_PARSER_API_URL="https://example.com/api/tenders"
SABY_AUTH_URL="https://online.saby.ru/auth/service/"
SABY_TENDER_API_URL="https://online.saby.ru/tender-api/service/"
SABY_LOGIN="replace-with-saby-login"
SABY_PASSWORD="replace-with-saby-password"
SABY_TENDER_METHODS="SbisTenderAPI.GetTenderList"
SABY_TENDER_REQUEST_NAMES="VR,Доступная среда,разработка"
SABY_PAGE_SIZE="50"
